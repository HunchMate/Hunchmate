# Copy this file to .env and update values
MAIL_API_PORT=8787
# Comma-separated allowlist of exact origins
MAIL_API_ALLOWED_ORIGIN=http://localhost:5173,https://your-domain.com

# Choose mail provider: resend or smtp
MAIL_PROVIDER=resend

# Resend configuration (recommended)
RESEND_API_KEY=<set-your-resend-api-key>
RESEND_FROM=Hunchmate <verified-sender@yourdomain.com>

# SMTP fallback (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=Hunchmate <your-smtp-user@example.com>

# Frontend API endpoint for invitation emails
VITE_INVITE_EMAIL_API_URL=http://localhost:8787/api/invitations/email

# Frontend API endpoint for contact-form emails
VITE_CONTACT_EMAIL_API_URL=http://localhost:8787/api/contact/email

# Recipient for contact form notifications (your support inbox)
CONTACT_FORM_TO=support@yourdomain.com

# Auth provider: local or firebase
VITE_AUTH_PROVIDER=firebase
VITE_FIREBASE_API_KEY=<set-your-firebase-api-key>
VITE_FIREBASE_AUTH_DOMAIN=<set-your-project>.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=<set-your-project-id>
VITE_FIREBASE_STORAGE_BUCKET=<set-your-project>.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=<set-your-sender-id>
VITE_FIREBASE_APP_ID=<set-your-app-id>
